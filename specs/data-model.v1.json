{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uno-protocol.org/specs/data-model.v1.json",
  "title": "UNO Core Data Model V1",
  "description": "Core protocol objects for verifiable agent continuity, centered on taxonomy and lineage.",
  "type": "object",
  "required": [
    "version",
    "objects"
  ],
  "properties": {
    "version": {
      "const": "1.0.0"
    },
    "objects": {
      "type": "object",
      "required": [
        "AgentID",
        "Assertion",
        "LineageLink",
        "ContinuityEvent",
        "WitnessReceipt"
      ],
      "properties": {
        "AgentID": {
          "$ref": "#/$defs/AgentID"
        },
        "Assertion": {
          "$ref": "#/$defs/Assertion"
        },
        "LineageLink": {
          "$ref": "#/$defs/LineageLink"
        },
        "ContinuityEvent": {
          "$ref": "#/$defs/ContinuityEvent"
        },
        "WitnessReceipt": {
          "$ref": "#/$defs/WitnessReceipt"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "URI": {
      "type": "string",
      "format": "uri"
    },
    "DateTime": {
      "type": "string",
      "format": "date-time"
    },
    "Digest": {
      "type": "object",
      "required": [
        "algorithm",
        "value"
      ],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": [
            "sha-256",
            "sha-512",
            "blake3"
          ]
        },
        "value": {
          "$ref": "#/$defs/NonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "Signature": {
      "type": "object",
      "required": [
        "keyId",
        "algorithm",
        "value"
      ],
      "properties": {
        "keyId": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "algorithm": {
          "type": "string",
          "enum": [
            "ed25519",
            "secp256k1",
            "p256"
          ]
        },
        "value": {
          "$ref": "#/$defs/NonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "TaxonomyRef": {
      "type": "object",
      "required": [
        "namespace",
        "path",
        "label"
      ],
      "properties": {
        "namespace": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "path": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/NonEmptyString"
          }
        },
        "label": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "version": {
          "$ref": "#/$defs/NonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "PublicKey": {
      "type": "object",
      "required": [
        "id",
        "algorithm",
        "publicKey"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "algorithm": {
          "type": "string",
          "enum": [
            "ed25519",
            "secp256k1",
            "p256"
          ]
        },
        "publicKey": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "rotated",
            "revoked"
          ],
          "default": "active"
        },
        "validFrom": {
          "$ref": "#/$defs/DateTime"
        },
        "validUntil": {
          "$ref": "#/$defs/DateTime"
        }
      },
      "additionalProperties": false
    },
    "AgentID": {
      "type": "object",
      "required": [
        "id",
        "controller",
        "keys",
        "taxonomy",
        "createdAt",
        "status"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "controller": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "displayName": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "keys": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/PublicKey"
          }
        },
        "taxonomy": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/TaxonomyRef"
          }
        },
        "lineageRoot": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "createdAt": {
          "$ref": "#/$defs/DateTime"
        },
        "updatedAt": {
          "$ref": "#/$defs/DateTime"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "superseded",
            "revoked",
            "archived"
          ]
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "Assertion": {
      "type": "object",
      "required": [
        "id",
        "issuer",
        "subject",
        "predicate",
        "contentDigest",
        "issuedAt",
        "signature"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "issuer": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "subject": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "predicate": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "taxonomy": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TaxonomyRef"
          }
        },
        "contentDigest": {
          "$ref": "#/$defs/Digest"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/URI"
          }
        },
        "issuedAt": {
          "$ref": "#/$defs/DateTime"
        },
        "expiresAt": {
          "$ref": "#/$defs/DateTime"
        },
        "continuityEventId": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "signature": {
          "$ref": "#/$defs/Signature"
        }
      },
      "additionalProperties": false
    },
    "LineageLink": {
      "type": "object",
      "required": [
        "id",
        "sourceAgentId",
        "targetAgentId",
        "relation",
        "assertedAt"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "sourceAgentId": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "targetAgentId": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "relation": {
          "type": "string",
          "enum": [
            "derived-from",
            "fork-of",
            "merged-from",
            "supersedes",
            "spawned-by",
            "trained-from"
          ]
        },
        "basisAssertionId": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "taxonomyInheritance": {
          "type": "string",
          "enum": [
            "full",
            "partial",
            "none"
          ],
          "default": "partial"
        },
        "assertedAt": {
          "$ref": "#/$defs/DateTime"
        },
        "notes": {
          "$ref": "#/$defs/NonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "ContinuityEvent": {
      "type": "object",
      "required": [
        "id",
        "agentId",
        "sequence",
        "eventType",
        "previousEventDigest",
        "payloadDigest",
        "recordedAt",
        "signature"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "agentId": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "eventType": {
          "type": "string",
          "enum": [
            "inception",
            "key-rotation",
            "taxonomy-update",
            "assertion-anchor",
            "lineage-update",
            "branch",
            "merge",
            "revocation"
          ]
        },
        "previousEventDigest": {
          "oneOf": [
            {
              "$ref": "#/$defs/Digest"
            },
            {
              "type": "null"
            }
          ]
        },
        "payloadDigest": {
          "$ref": "#/$defs/Digest"
        },
        "anchors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/URI"
          }
        },
        "lineageLinks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NonEmptyString"
          }
        },
        "taxonomySnapshot": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TaxonomyRef"
          }
        },
        "recordedAt": {
          "$ref": "#/$defs/DateTime"
        },
        "signature": {
          "$ref": "#/$defs/Signature"
        }
      },
      "additionalProperties": false
    },
    "WitnessReceipt": {
      "type": "object",
      "required": [
        "id",
        "eventId",
        "witness",
        "observedAt",
        "eventDigest",
        "signature"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "eventId": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "witness": {
          "$ref": "#/$defs/NonEmptyString"
        },
        "observedAt": {
          "$ref": "#/$defs/DateTime"
        },
        "eventDigest": {
          "$ref": "#/$defs/Digest"
        },
        "receiptIndex": {
          "type": "integer",
          "minimum": 0
        },
        "signature": {
          "$ref": "#/$defs/Signature"
        }
      },
      "additionalProperties": false
    }
  }
}
